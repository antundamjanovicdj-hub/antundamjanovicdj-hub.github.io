{
  "appId": "com.lifekompas.app",
  "appName": "LifeKompas",
  "webDir": "public",
  "bundledWebRuntime": false,

  "ios": {
  "contentInset": "never",
  "useSwiftPackageManager": true
},

  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#8B4513",
      "androidScaleType": "CENTER_CROP",
      "iosResizeMode": "aspectFit"
      },
    "CapacitorContacts": {
      "readContacts": true,
      "writeContacts": true
    }
  }
}