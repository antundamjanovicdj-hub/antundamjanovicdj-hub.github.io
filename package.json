{
  "name": "antundamjanovicdj-hub.github.io",
  "version": "1.0.0",
  "description": "",
  "main": "service-worker.js",
  "scripts": {
    "dev": "concurrently \"npm run watch:web\" \"npm run serve\"",
    "sync:web": "mkdir -p public && rsync -av --delete --exclude='.DS_Store' src/ public/",
    "cap:sync": "npm run sync:web && npx cap sync",
    "sync:android": "npm run sync:web && npx cap sync android",
    "run:android": "npm run sync:android && npx cap run android",
    "check:json": "node -e \"JSON.parse(require('fs').readFileSync('./package.json'))\"",
    "build:apk": "npm run check:json && npm run cap:sync && cd android && ./gradlew assembleDebug",
    "watch:web": "chokidar \"src/**/*\" --usePolling -c \"npm run sync:web\" --initial",
    "dev:web": "http-server public -p 3000 -c-1",
    "dev:full": "concurrently -k -n WATCH,SERVER -c blue,green \"npm run watch:web\" \"npm run dev:web\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antundamjanovicdj-hub/antundamjanovicdj-hub.github.io.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/antundamjanovicdj-hub/antundamjanovicdj-hub.github.io/issues"
  },
  "homepage": "https://github.com/antundamjanovicdj-hub/antundamjanovicdj-hub.github.io#readme",
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/local-notifications": "^8.0.1",
    "@capgo/capacitor-contacts": "^8.0.8",
    "@capacitor-community/image-to-text": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "http-server": "^14.1.1",
    "serve": "^14.2.6",
    "stylelint-config-standard": "^40.0.0"
  }
}
